# GaokaoGuide 配置文件
# 复制为 .env 后填入实际值

# ---- LLM 配置 ----
# 主模型（支持 OpenAI 兼容 API）
ZXF_LLM_PRIMARY_API_KEY=sk-你的key
ZXF_LLM_PRIMARY_MODEL=deepseek-v4-pro
ZXF_LLM_PRIMARY_BASE_URL=https://api.deepseek.com/v1
ZXF_LLM_PRIMARY_API_TYPE=auto

# 备用模型（主模型失败时自动切换）
ZXF_LLM_FALLBACK_API_KEY=sk-你的key
ZXF_LLM_FALLBACK_MODEL=deepseek-chat
ZXF_LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1
ZXF_LLM_FALLBACK_API_TYPE=auto

# ---- 向量模型 ----
ZXF_EMBEDDING_API_KEY=sk-你的key
ZXF_EMBEDDING_MODE=api

# ---- 服务端口 ----
GRADIO_PORT=7860
